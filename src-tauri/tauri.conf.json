{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-build/schema.json",
  "productName": "NeoTrix",
  "version": "0.18.0",
  "identifier": "ai.neotrix.desktop",
  "build": {
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "NeoTrix Desktop V2",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; style-src-attr 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; img-src 'self' data: https:; frame-src 'self'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "msi"],
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": ["openssl", "ca-certificates"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://releases.neotrix.ai/update/{{target}}/{{current_version}}"],
      "pubkey": "Z6H2pSM2XdraNQHZwul9ygc9EdWnFmV0DASod02i/R0"
    }
  }
}
