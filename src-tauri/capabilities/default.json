{
  "identifier": "default",
  "description": "Granular capability set for NeoTrix main window — core, shell, filesystem, notification, HTTP",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "fs:default",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-stat",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "http:default",
    "http:allow-fetch",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "deep-link:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
