name: core_hcube_vsa
description: "VSAEngine float-based vector operations — full test suite"

tests:
  - name: engine_bind_different_from_inputs
    description: "Bound vector is dissimilar to either input"
    imports:
      - "neotrix::core::nt_core_hcube::vsa::VSAEngine"
      - "neotrix::core::nt_core_hcube::vsa::VsaBackend"
    setup: |
      let engine = VSAEngine::new(4096);
      let a: Vec<f64> = (0..4096).map(|i| (i as f64).sin()).collect();
      let b: Vec<f64> = (0..4096).map(|i| (i as f64).cos()).collect();
      let c = engine.bind(&a, &b);
    code: |
      let sim_a = engine.similarity(&c, &a);
      let sim_b = engine.similarity(&c, &b);
      assert!(sim_a.abs() < 0.1);
      assert!(sim_b.abs() < 0.1);

  - name: engine_bundle_similar_to_components
    description: "Bundled vector is similar to all components"
    imports:
      - "neotrix::core::nt_core_hcube::vsa::VSAEngine"
      - "neotrix::core::nt_core_hcube::vsa::VsaBackend"
    setup: |
      let engine = VSAEngine::new(4096);
      let a: Vec<f64> = (0..4096).map(|i| (i as f64).sin()).collect();
      let b: Vec<f64> = (0..4096).map(|i| (i as f64).cos()).collect();
    code: |
      let c = engine.bundle(&[&a, &b]);
      assert!(engine.similarity(&c, &a) > 0.5);
      assert!(engine.similarity(&c, &b) > 0.5);

  - name: engine_permute_reversible
    description: "Permute is reversible for float VSA"
    imports:
      - "neotrix::core::nt_core_hcube::vsa::VSAEngine"
      - "neotrix::core::nt_core_hcube::vsa::VsaBackend"
    setup: |
      let engine = VSAEngine::new(4096);
      let v: Vec<f64> = (0..4096).map(|i| (i as f64).sin()).collect();
    code: |
      let p = engine.permute(&v, 100);
      let r = engine.permute(&p, -100);
      let sim = engine.similarity(&r, &v);
      assert!((sim - 1.0).abs() < 1e-10);

  - name: engine_self_similarity_one
    description: "Self-similarity is 1.0"
    imports:
      - "neotrix::core::nt_core_hcube::vsa::VSAEngine"
      - "neotrix::core::nt_core_hcube::vsa::VsaBackend"
    setup: |
      let engine = VSAEngine::new(4096);
      let v: Vec<f64> = (0..4096).map(|i| (i as f64).sin()).collect();
    code: |
      let sim = engine.similarity(&v, &v);
      assert!((sim - 1.0).abs() < 1e-10);

  - name: engine_dimensions
    description: "Engine reports correct dimensions"
    imports:
      - "neotrix::core::nt_core_hcube::vsa::VSAEngine"
      - "neotrix::core::nt_core_hcube::vsa::VsaBackend"
    code: |
      let engine = VSAEngine::new(1024);
      assert_eq!(engine.dimensions(), 1024);
