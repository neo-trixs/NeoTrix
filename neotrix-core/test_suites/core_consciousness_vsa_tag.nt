name: core_consciousness_vsa_tag
description: "VsaTag self-world boundary tests"

tests:
  - name: vsa_origin_self
    description: "Self-origin tag returns is_self()=true"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let tag = VsaOrigin::Self_(VsaSelfCategory::Thought);
      assert!(tag.is_self());
      assert!(!tag.is_world());

  - name: vsa_origin_world
    description: "World-origin tag returns is_world()=true"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaWorldCategory"
    code: |
      let tag = VsaOrigin::World(VsaWorldCategory::UserInput);
      assert!(!tag.is_self());
      assert!(tag.is_world());

  - name: vsa_tagged_roundtrip
    description: "VsaTagged preserves vector and tag through new()"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let vector = vec![1; 256];
      let tag = VsaOrigin::Self_(VsaSelfCategory::Memory);
      let tagged = VsaTagged::new(vector.clone(), tag);
      assert_eq!(tagged.vector, vector);
      assert_eq!(tagged.tag, tag);
      assert!(tagged.is_self());

  - name: self_categories_distinct
    description: "VsaSelfCategory::all() returns distinct categories"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let cats = VsaSelfCategory::all();
      let mut unique = cats.to_vec();
      unique.sort_by_key(|c| *c as u8);
      unique.dedup();
      assert_eq!(cats.len(), unique.len());

  - name: world_categories_distinct
    description: "VsaWorldCategory::all() returns distinct categories"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaWorldCategory"
    code: |
      let cats = VsaWorldCategory::all();
      let mut unique = cats.to_vec();
      unique.sort_by_key(|c| *c as u8);
      unique.dedup();
      assert_eq!(cats.len(), unique.len());

  - name: confidence_clamping
    description: "with_confidence clamps to [0.0, 1.0]"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let vector = vec![0; 10];
      let tag = VsaOrigin::Self_(VsaSelfCategory::Emotion);
      let tagged = VsaTagged::new(vector, tag).with_confidence(1.5);
      assert!((tagged.confidence - 1.0).abs() < 1e-9);

  - name: salience_default
    description: "Default salience is 0.5"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought));
      assert!((tagged.salience - 0.5).abs() < 1e-9);

  - name: with_salience_clamping
    description: "with_salience clamps to [0.0, 1.0]"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought))
          .with_salience(1.5);
      assert!((tagged.salience - 1.0).abs() < 1e-9);

  - name: provenance_default_none
    description: "Provenance is None by default"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought));
      assert!(tagged.provenance.is_none());

  - name: with_provenance_attaches_chain
    description: "with_provenance attaches a ProvenanceChain"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::KnowledgeLayer"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::PerceptionMeta"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::PerceptionSource"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::ProvenanceChain"
    code: |
      let raw = KnowledgeLayer::Raw(PerceptionMeta {
          source_type: PerceptionSource::WebFetch,
          raw_confidence: 0.9,
          timestamp: 1000,
      });
      let chain = ProvenanceChain::new(vec![(raw, 1000)]);
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought))
          .with_provenance(chain);
      assert!(tagged.provenance.is_some());

  - name: knowledge_layer_none_without_provenance
    description: "knowledge_layer() is None without provenance"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought));
      assert!(tagged.knowledge_layer().is_none());

  - name: knowledge_layer_returns_topmost
    description: "knowledge_layer() returns the topmost Structured layer"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::ContextMeta"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::KnowledgeLayer"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::PerceptionMeta"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::PerceptionSource"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::ProvenanceChain"
    code: |
      let raw = KnowledgeLayer::Raw(PerceptionMeta {
          source_type: PerceptionSource::WebFetch,
          raw_confidence: 0.9,
          timestamp: 1000,
      });
      let structured = KnowledgeLayer::Structured(ContextMeta {
          source_ids: vec!["src".into()],
          processing_steps: vec!["parse".into()],
          contextual_confidence: 0.8,
      });
      let chain = ProvenanceChain::new(vec![(raw, 1000), (structured, 2000)]);
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought))
          .with_provenance(chain);
      assert!(matches!(tagged.knowledge_layer(), Some(KnowledgeLayer::Structured(_))));

  - name: retention_score_with_provenance_factors_in_confidence
    description: "retention_score_with_provenance incorporates provenance confidence"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::ContextMeta"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::KnowledgeLayer"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::PerceptionMeta"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::PerceptionSource"
      - "neotrix::core::nt_core_consciousness::source_hierarchy::ProvenanceChain"
    code: |
      let raw = KnowledgeLayer::Raw(PerceptionMeta {
          source_type: PerceptionSource::WebFetch,
          raw_confidence: 0.9,
          timestamp: 1000,
      });
      let structured = KnowledgeLayer::Structured(ContextMeta {
          source_ids: vec!["src".into()],
          processing_steps: vec!["parse".into()],
          contextual_confidence: 0.8,
      });
      let chain = ProvenanceChain::new(vec![(raw, 1000), (structured, 2000)]);
      let tagged = VsaTagged::new(vec![1; 16], VsaOrigin::Self_(VsaSelfCategory::Thought))
          .with_provenance(chain);
      let with_prov = tagged.retention_score_with_provenance();
      assert!((with_prov - 0.872).abs() < 1e-9);

  - name: retention_score_without_provenance_falls_back
    description: "retention_score_with_provenance falls back to base retention_score"
    imports:
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaTagged"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaOrigin"
      - "neotrix::core::nt_core_consciousness::vsa_tag::VsaSelfCategory"
    code: |
      let tagged = VsaTagged::new(vec![0; 16], VsaOrigin::Self_(VsaSelfCategory::Thought));
      assert!((tagged.retention_score_with_provenance() - tagged.retention_score()).abs() < 1e-9);
